# Copy this to .env (which is git-ignored) and fill in real values.
# Never commit the real .env, and never paste tokens into chats/screenshots.
RUNALYZE_TOKEN=your_runalyze_personal_api_token

# LLM adjustment layer (§6c) — optional; blank keeps the AI features dormant.
ANTHROPIC_API_KEY=your_anthropic_api_key

# Nightly auto-sync on the private/writable instance (defaults shown):
# SH_TZ=UTC            # your IANA timezone for the sync hour, e.g. Europe/Lisbon, America/New_York
# SH_SYNC_AT=22:30     # local time (in SH_TZ) to pull the day's activities
# SH_SCHEDULE=0        # disable the nightly pull entirely

# Optional personalization (all blank by default):
# SH_SEED_OBJECTIVE=Berlin Marathon|2026-09-27|marathon|finish|A   # seed a first race (label|date|type|target|priority)
# SH_ATHLETE_CONTEXT=masters runner returning from injury, cleared by my doctor   # one line, injected into the LLM prompts
# SH_WEATHER_CITIES=Lisbon,38.72,-9.14;Tokyo,35.68,139.69          # header weather widget; blank = hidden
# SH_HOUSE_URL=https://example.com                                  # optional back-link in the header
# SH_HOUSE_NAME=home                                                # label for that link (defaults to the URL)

# Public read-only container only (set in docker-compose, not here):
# SH_READONLY=1        # blocks all writes + withholds medical sections; no tokens on that container
